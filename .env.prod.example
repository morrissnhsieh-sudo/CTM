# ============================================================
# CTM Platform — Production environment variables
# Copy to .env.prod and fill in your values
# ============================================================

# ── Domain ─────────────────────────────────────────────────
# Your base domain. CTM will use subdomains:
#   app.DOMAIN    Frontend
#   api.DOMAIN    REST API
#   auth.DOMAIN   Keycloak
#   collab.DOMAIN WebSocket (CRDT)
#   chat.DOMAIN   Socket.io (Messaging)
DOMAIN=ctm.example.com

# ── Secrets (read from /etc/ctm/secrets/ at runtime) ───────
# These are auto-read from Docker secrets files.
# Set here only if NOT using Docker secrets.
PG_USER=ctm
PG_PASSWORD=         # leave blank if using /etc/ctm/secrets/pg_password.txt
REDIS_PASSWORD=      # leave blank if using /etc/ctm/secrets/redis_password.txt
MINIO_USER=ctm_admin
MINIO_PASSWORD=      # leave blank if using /etc/ctm/secrets/minio_password.txt

# ── Internal service token ──────────────────────────────────
# Random 32+ char string for service-to-service auth (mTLS substitute)
INTERNAL_TOKEN_SECRET=change-me-to-a-random-32char-string

# ── NextAuth.js ─────────────────────────────────────────────
# openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-base64-string

# ── Vertex AI ───────────────────────────────────────────────
VERTEX_PROJECT_ID=d-sxd110x-ssd1-aaos
VERTEX_REGION=us-east5
# Key file must be at /etc/ctm/secrets/vertex_key.json on the server

# ── Optional LLM fallback ───────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Email ───────────────────────────────────────────────────
RESEND_API_KEY=

# ── Container registry ─────────────────────────────────────
# Leave blank to build locally on the server
# Or set to your registry: ghcr.io/yourorg  /  docker.io/yourorg
REGISTRY=
VERSION=latest
